{
	"name": "local-agent",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"start": "npm run build -w packages/web && npm run start -w packages/agent",
		"dev": "npm run dev -w packages/agent",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "npm test --workspaces --if-present"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0"
	}
}
